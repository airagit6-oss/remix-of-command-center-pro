# SECURITY CONFIGURATION TEMPLATE
# Software Vala NEXUS - Enterprise Security Settings
# =====================================================

# ============================================================
# DATABASE SECURITY
# ============================================================
DATABASE_URL="postgresql://user:password@localhost:5432/softwarevala?schema=public"

# ============================================================
# JWT & AUTHENTICATION SECURITY
# ============================================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars-REQUIRED"
JWT_EXPIRATION="24h"
JWT_REFRESH_SECRET="refresh-secret-key-different-from-jwt-secret-REQUIRED"
JWT_REFRESH_EXPIRATION="7d"

# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=3001
NODE_ENV=production
REQUEST_TIMEOUT=30000
BODY_LIMIT_MB=1

# ============================================================
# CORS (Cross-Origin Resource Sharing) SECURITY
# ============================================================
# Multiple allowed origins (comma-separated)
CORS_ORIGINS="http://localhost:4174,http://localhost:4176,https://softwarevala.net,https://app.softwarevala.net"
CORS_CREDENTIALS=true
CORS_METHODS="GET,HEAD,PUT,PATCH,POST,DELETE"
CORS_HEADERS="Content-Type,Authorization"
CORS_EXPOSE_HEADERS="X-Total-Count,X-Page-Number"
CORS_MAX_AGE=86400

# ============================================================
# API SECURITY - Rate Limiting
# ============================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_ADMIN_MAX=200
RATE_LIMIT_SKIP_HEALTH_CHECK=true

# ============================================================
# API KEY SECURITY
# ============================================================
API_KEY_HEADER="X-API-Key"
API_KEY_REQUIRED=true
VALID_API_KEYS="key_prod_xxx,key_prod_yyy,key_dev_xxx"

# ============================================================
# HELMET SECURITY HEADERS
# ============================================================
HELMET_CONTENT_SECURITY_POLICY=true
HELMET_CROSS_ORIGIN_EMBEDDER_POLICY=true
HELMET_CROSS_ORIGIN_OPENER_POLICY=true
HELMET_CROSS_ORIGIN_RESOURCE_POLICY=true
HELMET_DNS_PREFETCH_CONTROL=true
HELMET_FRAMEGUARD=SAMEORIGIN
HELMET_STRICT_TRANSPORT_SECURITY=31536000
HELMET_X_CONTENT_TYPE_OPTIONS=nosniff
HELMET_X_FRAME_OPTIONS=DENY
HELMET_X_POWERED_BY=false

# ============================================================
# APP CONFIGURATION
# ============================================================
APP_URL="http://localhost:3000"
APP_NAME="Software Vala NEXUS"
ENVIRONMENT=production

# ============================================================
# CACHE & PERFORMANCE
# ============================================================
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""
CACHE_TTL_DEFAULT=3600
CACHE_TTL_SHORT=300
CACHE_TTL_LONG=86400

# ============================================================
# PAYMENT GATEWAYS - KEEP SECRETS SAFE!
# ============================================================
STRIPE_PUBLIC_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_MODE="sandbox"

# ============================================================
# EMAIL CONFIGURATION
# ============================================================
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USER=""
MAIL_PASSWORD=""
MAIL_FROM="noreply@softwarevala.net"
MAIL_FROM_NAME="Software Vala"

# ============================================================
# FILE UPLOAD SECURITY
# ============================================================
UPLOAD_MAX_FILE_SIZE_MB=500
UPLOAD_ALLOWED_EXTENSIONS="zip,pdf,doc,docx,xls,xlsx,ppt,pptx,jpg,png,gif,svg"
UPLOAD_SCAN_MALWARE=true
UPLOAD_VIRUS_SCAN_ENGINE="clamav"
S3_BUCKET_NAME=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# ============================================================
# AUDIT & LOGGING
# ============================================================
LOG_LEVEL="info"
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90
SENSITIVE_FIELDS_TO_HIDE="password,pin,token,secret,api_key,credit_card"

# ============================================================
# SECURITY MONITORING
# ============================================================
SENTRY_DSN=""
SECURITY_ALERT_EMAIL="security@softwarevala.net"
BREACH_DETECTION_ENABLED=true
SUSPICIOUS_ACTIVITY_THRESHOLD=5

# ============================================================
# DATA PROTECTION & ENCRYPTION
# ============================================================
ENCRYPTION_KEY="32-character-key-for-aes-256-CHANGE"
ENCRYPTION_ALGORITHM="aes-256-gcm"
DATA_RETENTION_DAYS=365
GDPR_ENABLED=true

# ============================================================
# TWO-FACTOR AUTHENTICATION
# ============================================================
2FA_ENABLED=true
2FA_WINDOW=30
2FA_DIGITS=6
2FA_ISSUER="Software Vala"

# ============================================================
# SESSION MANAGEMENT
# ============================================================
SESSION_TIMEOUT_MINUTES=30
SESSION_ABSOLUTE_TIMEOUT_HOURS=24
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict

# ============================================================
# SECURITY KEYS
# ============================================================
HMAC_KEY="hmac-secret-key-for-integrity-checks"
NONCE_EXPIRATION_SECONDS=300

# ============================================================
# THIRD-PARTY SERVICES
# ============================================================
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GITHUB_OAUTH_CLIENT_ID=""
GITHUB_OAUTH_CLIENT_SECRET=""

# ============================================================
# FEATURE FLAGS & PILOT PROGRAMS
# ============================================================
FEATURE_2FA=true
FEATURE_BIOMETRIC=true
FEATURE_SOCIAL_LOGIN=true
FEATURE_OFFLINE_MODE=false
