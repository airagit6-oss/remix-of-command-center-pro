generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Base
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          UserRole  @default(CUSTOMER)
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime @updatedAt

  authorProfile    AuthorProfile?
  resellerProfile  ResellerProfile?
  cart             Cart?
  orders           Order[]
  subscriptions    Subscription[]
  referrals        Referral[]  @relation("Referrer")
  referredBy       Referral?   @relation("ReferredUser")
  leads            Lead[]
  commissions     Commission[]
  payouts         Payout[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  notificationPreferences NotificationPreference[]
  wallet           Wallet?
  reviews          Review[]
  comments         Comment[]
  wishlist         Wishlist[]
  twoFactorSecret  String?
  twoFactorEnabled Boolean   @default(false)
  sessions         Session[]
  devices          Device[]
  securityEvents   SecurityEvent[]
  activityLogs     ActivityLog[]
  
  // Support Ecosystem Relations
  supportTickets   SupportTicket[]
  ticketMessages   TicketMessage[]
  chatSessions     LiveChatSession[]
  kbArticles       KnowledgeBaseArticle[]
  forumPosts       ForumPost[]
  forumComments    ForumComment[]
  bugReports       BugReport[]
  featureRequests  FeatureRequest[]
  customerFeedback CustomerFeedback[]
  
  // Finance OS Relations
  commissionLedger CommissionLedger[]
  settlementLedger SettlementLedger[]
  
  // Achievement System Relations
  achievementProfile  AchievementProfile?
  spotlightedAs       Spotlight?    @relation("Spotlight")
  hallOfFameEntries   HallOfFame[]  @relation("HallOfFame")
  
  // Digital Asset Protection Relations
  downloadWatermarks DownloadWatermark[]
  downloadFingerprints DownloadFingerprint[]
  
  // Product Health Center Relations
  crashReports CrashReport[]
  productBugReports ProductBugReport[]
  userComplaints UserComplaint[]
  
  // Customer Success Center Relations
  customerOnboarding CustomerOnboarding?
  usageTracking UsageTracking[]
  adoptionTracking AdoptionTracking[]
  renewalPredictions RenewalPrediction[]
  churnPredictions ChurnPrediction[]
  campaignTargets CampaignTarget[]
  
  // Partner OS Relations
  partner Partner?
  
  // Enterprise Commission Engine Relations
  commissionLedgerEntries CommissionLedgerEntry[]
  teamCommissionsAsLead TeamCommission[] @relation("TeamCommissionLead")
  teamCommissionsAsMember TeamCommission[] @relation("TeamCommissionMember")
  performanceCommissions PerformanceCommission[]
  
  // Renewal Commission Center Relations
  licenseRenewals LicenseRenewalTracking[]
  subscriptionRenewals SubscriptionRenewalTracking[]
  renewalRevenues RenewalRevenue[]
  renewalForecasts RenewalForecast[]
  autoRenewalCommissions AutoRenewalCommission[]
  
  // B2B Sales Center Relations
  corporateLeadsAsAssignee CorporateLead[] @relation("CorporateLeadAssignee")
  enterpriseLeadsAsAssignee EnterpriseLead[] @relation("EnterpriseLeadAssignee")
  bulkDealsAsAssignee BulkDeal[] @relation("BulkDealAssignee")

  @@index([email])
  @@index([role])
}

enum UserRole {
  GUEST
  CUSTOMER
  AUTHOR
  RESELLER
  ADMIN
  SUPER_ADMIN
}

// Author Profile
model AuthorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  bio             String?
  website         String?
  socialLinks     Json?
  
  isKYCVerified   Boolean  @default(false)
  kycSubmittedAt  DateTime?
  kycVerifiedAt   DateTime?
  kycDocuments    Json?
  
  totalRevenue    Decimal  @default(0) @db.Decimal(20, 2)
  totalSales      Int      @default(0)
  followers       Int      @default(0)
  rating          Decimal  @default(0) @db.Decimal(3, 2)
  
  availableBalance Decimal @default(0) @db.Decimal(20, 2)
  pendingBalance    Decimal @default(0) @db.Decimal(20, 2)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  products        Product[]
  earnings        AuthorEarnings[]
  authorAnalytics AuthorAnalytics[]

  @@index([userId])
  @@index([isKYCVerified])
}

// Reseller Profile
model ResellerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  referralCode    String   @unique
  referralLink    String?
  
  totalReferrals  Int      @default(0)
  totalLeads      Int      @default(0)
  conversionRate  Decimal  @default(0) @db.Decimal(5, 2)
  
  totalCommissions Decimal @default(0) @db.Decimal(20, 2)
  availableBalance Decimal @default(0) @db.Decimal(20, 2)
  pendingBalance    Decimal @default(0) @db.Decimal(20, 2)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  leads           Lead[]
  commissions     Commission[]
  earnings        ResellerEarnings[]
  resellerAnalytics ResellerAnalytics[]

  @@index([userId])
  @@index([referralCode])
}

// Product
model Product {
  id          String       @id @default(cuid())
  authorId    String
  author      AuthorProfile @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  name        String
  description String
  price       Decimal      @db.Decimal(20, 2)
  status      ProductStatus @default(DRAFT)
  
  media       Json?
  tags        String[]
  categoryId  String?
  category    Category?   @relation(fields: [categoryId], references: [id])
  
  sales       Int          @default(0)
  revenue     Decimal      @default(0) @db.Decimal(20, 2)
  rating      Decimal      @default(0) @db.Decimal(3, 2)
  reviews     Int          @default(0)
  
  publishedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  orderItems  OrderItem[]
  mediaFiles  ProductMedia[]
  reviews     Review[]
  wishlist    Wishlist[]
  approval    ProductApproval?
  leakReports LeakReport[]
  crashReports CrashReport[]
  productBugReports ProductBugReport[]
  issues      Issue[]
  knownIssues KnownIssue[]
  versionHealth VersionHealth[]
  userComplaints UserComplaint[]

  @@index([authorId])
  @@index([status])
  @@index([categoryId])
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  SUSPENDED
}

// Product Media
model ProductMedia {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  type      MediaType
  url       String
  alt       String?
  order     Int      @default(0)
  
  createdAt DateTime @default(now())

  @@index([productId])
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
}

// Order
model Order {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  totalAmount Decimal  @db.Decimal(20, 2)
  status      OrderStatus @default(PENDING)
  
  referralId  String?
  referral    Referral? @relation(fields: [referralId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[]
  paymentIntents PaymentIntent[]
  invoices    Invoice[]
  licenses    License[]
  refunds     Refund[]
  taxRecords  TaxRecord[]

  @@index([userId])
  @@index([status])
  @@index([referralId])
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  CANCELLED
  REFUNDED
}

// Order Item
model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  
  quantity  Int
  price     Decimal  @db.Decimal(20, 2)
  total     Decimal  @db.Decimal(20, 2)
  
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([productId])
}

// Referral
model Referral {
  id              String   @id @default(cuid())
  referrerId      String
  referrer        User     @relation("Referrer", fields: [referrerId], references: [id])
  referredUserId  String   @unique
  referredUser    User     @relation("ReferredUser", fields: [referredUserId], references: [id])
  
  code            String
  status          ReferralStatus @default(PENDING)
  commission      Decimal? @db.Decimal(20, 2)
  
  orderId         String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([referrerId])
  @@index([referredUserId])
  @@index([code])
  @@index([status])
}

enum ReferralStatus {
  PENDING
  CONVERTED
  EXPIRED
  CANCELLED
}

// Lead
model Lead {
  id          String     @id @default(cuid())
  resellerId  String
  reseller    ResellerProfile @relation(fields: [resellerId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?      @relation(fields: [userId], references: [id])
  
  name        String
  email       String
  phone       String?
  source      String
  notes       String?
  status      LeadStatus @default(NEW)
  value       Decimal?   @db.Decimal(20, 2)
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  activities  LeadActivity[]

  @@index([resellerId])
  @@index([userId])
  @@index([email])
  @@index([status])
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

// Lead Activity
model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  action    String
  notes     String?
  
  createdAt DateTime @default(now())

  @@index([leadId])
}

// Commission
model Commission {
  id          String           @id @default(cuid())
  resellerId  String
  reseller    ResellerProfile  @relation(fields: [resellerId], references: [id])
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  
  orderId     String?
  referralId  String?
  
  type        CommissionType
  amount      Decimal          @db.Decimal(20, 2)
  rate        Decimal          @db.Decimal(5, 2)
  
  status      CommissionStatus @default(PENDING)
  
  processedAt DateTime?
  approvedBy  String?
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([resellerId])
  @@index([userId])
  @@index([status])
  @@index([type])
}

enum CommissionType {
  REFERRAL
  LEAD_CONVERSION
  RECURRING
  BONUS
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
  HELD
}

// Commission Rule
model CommissionRule {
  id          String   @id @default(cuid())
  name        String
  type        CommissionType
  
  rate        Decimal  @db.Decimal(5, 2)
  minAmount   Decimal? @db.Decimal(20, 2)
  maxAmount   Decimal? @db.Decimal(20, 2)
  
  conditions  Json?
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([isActive])
}

// Payout
model Payout {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  
  amount      Decimal      @db.Decimal(20, 2)
  method      PayoutMethod
  status      PayoutStatus @default(PENDING)
  
  accountDetails Json?
  
  requestedAt DateTime     @default(now())
  processedAt DateTime?
  
  transactionId String?
  notes       String?
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
  @@index([status])
  @@index([requestedAt])
}

enum PayoutMethod {
  BANK_TRANSFER
  PAYPAL
  CRYPTO
  CHECK
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// Author Earnings
model AuthorEarnings {
  id          String   @id @default(cuid())
  authorId    String
  author      AuthorProfile @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  orderId     String?
  productId   String?
  
  type        EarningType
  amount      Decimal  @db.Decimal(20, 2)
  
  status      EarningStatus @default(PENDING)
  
  createdAt   DateTime @default(now())

  @@index([authorId])
  @@index([status])
  @@index([type])
}

enum EarningType {
  SALE
  REFUND
  BONUS
  ADJUSTMENT
}

enum EarningStatus {
  PENDING
  AVAILABLE
  PAID
  HELD
}

// Reseller Earnings
model ResellerEarnings {
  id          String   @id @default(cuid())
  resellerId  String
  reseller    ResellerProfile @relation(fields: [resellerId], references: [id], onDelete: Cascade)
  
  commissionId String?
  
  type        EarningType
  amount      Decimal  @db.Decimal(20, 2)
  
  status      EarningStatus @default(PENDING)
  
  createdAt   DateTime @default(now())

  @@index([resellerId])
  @@index([status])
  @@index([type])
}

// Author Analytics
model AuthorAnalytics {
  id          String   @id @default(cuid())
  authorId    String
  author      AuthorProfile @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  date        DateTime @db.Date
  metric      String
  value       Decimal  @db.Decimal(20, 2)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())

  @@unique([authorId, date, metric])
  @@index([authorId])
  @@index([date])
}

// Reseller Analytics
model ResellerAnalytics {
  id          String   @id @default(cuid())
  resellerId  String
  reseller    ResellerProfile @relation(fields: [resellerId], references: [id], onDelete: Cascade)
  
  date        DateTime @db.Date
  metric      String
  value       Decimal  @db.Decimal(20, 2)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())

  @@unique([resellerId, date, metric])
  @@index([resellerId])
  @@index([date])
}

// KYC Record
model KYCRecord {
  id          String   @id @default(cuid())
  userId      String
  
  type        KYCType
  status      KYCStatus @default(PENDING)
  
  documents   Json
  notes       String?
  
  submittedAt DateTime @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  
  rejectionReason String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

enum KYCType {
  INDIVIDUAL
  BUSINESS
}

enum KYCStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

// Notification
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      NotificationType
  title     String
  message   String
  data      Json?
  
  channels  NotificationChannel[] // Which channels this notification was sent to
  status    NotificationStatus @default(SENT)
  
  isRead    Boolean  @default(false)
  readAt    DateTime?
  
  sentAt    DateTime @default(now())
  
  templateId String?
  template   NotificationTemplate? @relation(fields: [templateId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([status])
  @@index([createdAt])
}

enum NotificationType {
  ORDER
  PAYOUT
  COMMISSION
  REFERRAL
  LEAD
  PRODUCT
  SYSTEM
  ALERT
  LICENSE
  WALLET
  SECURITY
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WHATSAPP
  PUSH
  SMS
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
}

// Notification Template
model NotificationTemplate {
  id          String   @id @default(cuid())
  
  name        String   @unique
  type        NotificationType
  channels    NotificationChannel[]
  
  subject     String? // For email/push
  body        String   // Template body with placeholders
  htmlBody    String? // HTML version for email
  
  variables   Json? // Available variables in template
  
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  notifications Notification[]

  @@index([type])
  @@index([isActive])
}

// Notification Preference
model NotificationPreference {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        NotificationType
  channels    NotificationChannel[]
  enabled     Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, type])
  @@index([userId])
  @@index([type])
}

// Notification History
model NotificationHistory {
  id          String   @id @default(cuid())
  userId      String
  
  type        NotificationType
  channel     NotificationChannel
  
  status      NotificationStatus
  
  subject     String?
  body        String
  
  error       String?
  
  sentAt      DateTime @default(now())
  deliveredAt DateTime?
  
  metadata    Json?

  @@index([userId])
  @@index([type])
  @@index([channel])
  @@index([status])
  @@index([sentAt])
}

// Feature Flag
model FeatureFlag {
  id          String   @id @default(cuid())
  
  key         String   @unique
  name        String
  description String?
  
  enabled     Boolean  @default(true)
  
  // Targeting
  roles       UserRole[]
  countries   String[] // ISO country codes
  userSegments String[] // e.g., 'beta', 'premium', 'enterprise'
  
  // A/B Testing
  isABTest    Boolean  @default(false)
  variantA    Json?    // Configuration for variant A
  variantB    Json?    // Configuration for variant B
  splitPercentage Int @default(50) // 0-100
  
  // Metadata
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([enabled])
  @@index([isABTest])
}

// Queue Job
model QueueJob {
  id          String   @id @default(cuid())
  
  queue       QueueType
  type        String   // Job type within queue
  priority    Int      @default(0) // Higher priority = processed first
  
  data        Json
  status      JobStatus @default(PENDING)
  
  attempts    Int      @default(0)
  maxAttempts Int      @default(3)
  
  error       String?
  errorMessage Json?
  
  scheduledAt DateTime? // For delayed jobs
  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([queue])
  @@index([status])
  @@index([priority])
  @@index([scheduledAt])
  @@index([createdAt])
}

enum QueueType {
  EMAIL
  NOTIFICATION
  LICENSE
  WEBHOOK
  PAYOUT
  REPORT
  CLEANUP
  SYNC
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  RETRYING
}

// Scheduled Job
model ScheduledJob {
  id          String   @id @default(cuid())
  
  name        String
  type        JobType
  description String?
  
  // Schedule
  cronExpression String? // e.g., "0 0 * * *" for daily at midnight
  intervalMinutes Int? // Alternative to cron: run every X minutes
  runAt      DateTime? // One-time scheduled job
  
  enabled     Boolean  @default(true)
  
  // Execution tracking
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  
  successCount Int @default(0)
  failureCount Int @default(0)
  
  // Configuration
  config      Json?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([enabled])
  @@index([nextRunAt])
  @@index([cronExpression])
}

enum JobType {
  RENEWAL
  CLEANUP
  REPORT
  BACKUP
  REMINDER
  SYNC
}

// Event
model Event {
  id          String   @id @default(cuid())
  
  eventType  EventType
  aggregateId String   // ID of the entity that triggered the event
  aggregateType String // Type of entity (Order, Payment, License, etc.)
  
  data        Json
  metadata    Json?
  
  publishedAt DateTime @default(now())
  
  @@index([eventType])
  @@index([aggregateId])
  @@index([aggregateType])
  @@index([publishedAt])
}

enum EventType {
  ORDER_CREATED
  ORDER_UPDATED
  ORDER_CANCELLED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  PAYMENT_REFUNDED
  LICENSE_CREATED
  LICENSE_ACTIVATED
  LICENSE_EXPIRED
  LICENSE_REVOKED
  COMMISSION_CREATED
  COMMISSION_PAID
  PAYOUT_CREATED
  PAYOUT_PROCESSED
  NOTIFICATION_TRIGGERED
  USER_REGISTERED
  USER_VERIFIED
  PRODUCT_CREATED
  PRODUCT_UPDATED
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_RENEWED
  SUBSCRIPTION_CANCELLED
}

// Event Subscription
model EventSubscription {
  id          String   @id @default(cuid())
  
  eventType   EventType
  webhookUrl  String
  secret      String? // For webhook signature verification
  
  enabled     Boolean  @default(true)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([eventType])
  @@index([enabled])
}

// Event Log
model EventLog {
  id          String   @id @default(cuid())
  
  eventId     String
  subscriptionId String
  
  eventType   EventType
  webhookUrl  String
  
  status      EventDeliveryStatus @default(PENDING)
  
  statusCode  Int?
  response    String?
  error       String?
  
  attempts    Int      @default(0)
  
  sentAt      DateTime?
  deliveredAt DateTime?
  failedAt    DateTime?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([eventId])
  @@index([subscriptionId])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
}

enum EventDeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  RETRYING
}

// Custom Field Definition
model CustomFieldDefinition {
  id          String   @id @default(cuid())
  
  entityType CustomFieldType
  name        String
  key         String
  type        FieldType
  
  required    Boolean  @default(false)
  unique      Boolean  @default(false)
  
  options     Json?    // For select/multi-select fields
  validation  Json?    // Validation rules (min, max, pattern, etc.)
  defaultValue Json?
  
  enabled     Boolean  @default(true)
  order       Int      @default(0)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  values      CustomFieldValue[]

  @@unique([entityType, key])
  @@index([entityType])
  @@index([enabled])
  @@index([key])
}

enum CustomFieldType {
  PRODUCT
  AUTHOR
  CUSTOMER
  RESELLER
}

enum FieldType {
  TEXT
  NUMBER
  EMAIL
  URL
  DATE
  DATETIME
  BOOLEAN
  SELECT
  MULTI_SELECT
  TEXTAREA
  JSON
}

// Custom Field Value
model CustomFieldValue {
  id          String   @id @default(cuid())
  
  fieldId     String
  field       CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  
  entityId    String   // ID of the entity (product, author, customer, reseller)
  value       Json
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([fieldId, entityId])
  @@index([fieldId])
  @@index([entityId])
}

// Form Definition
model FormDefinition {
  id          String   @id @default(cuid())
  
  type        FormType
  name        String
  description String?
  
  schema      Json     // Form schema (fields, validation, etc.)
  config      Json?    // Form configuration (submit action, notifications, etc.)
  
  enabled     Boolean  @default(true)
  published   Boolean  @default(false)
  
  version     Int      @default(1)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions FormSubmission[]

  @@index([type])
  @@index([enabled])
  @@index([published])
}

enum FormType {
  KYC
  LEAD
  SUPPORT
  CUSTOM
}

// Form Submission
model FormSubmission {
  id          String   @id @default(cuid())
  
  formId      String
  form        FormDefinition @relation(fields: [formId], references: [id], onDelete: Cascade)
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  
  data        Json     // Submitted form data
  status      FormSubmissionStatus @default(PENDING)
  
  notes       String?
  
  submittedAt DateTime @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?
  
  metadata    Json?

  @@index([formId])
  @@index([userId])
  @@index([status])
  @@index([submittedAt])
}

enum FormSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
  UNDER_REVIEW
}

// System Health Check
model SystemHealthCheck {
  id          String   @id @default(cuid())
  
  component   HealthComponent
  status      HealthStatus
  
  metrics     Json?    // Component-specific metrics
  message     String?  // Status message or error
  
  checkedAt   DateTime @default(now())

  @@index([component])
  @@index([status])
  @@index([checkedAt])
}

enum HealthComponent {
  API
  DATABASE
  QUEUE
  WEBHOOK
  CRON
  STORAGE
  REDIS
  CDN
}

enum HealthStatus {
  HEALTHY
  DEGRADED
  UNHEALTHY
  UNKNOWN
}

// Config Rule
model ConfigRule {
  id          String   @id @default(cuid())
  
  type        ConfigType
  category    String   // e.g., 'TAX_RATE', 'COMMISSION_PERCENTAGE', 'LICENSE_DURATION'
  key         String
  value       Json
  
  description String?
  
  enabled     Boolean  @default(true)
  priority    Int      @default(0)
  
  validFrom   DateTime?
  validTo     DateTime?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([type, key])
  @@index([type])
  @@index([category])
  @@index([enabled])
  @@index([validFrom, validTo])
}

enum ConfigType {
  TAX
  COMMISSION
  LICENSE
  RENEWAL
  REFERRAL
  NOTIFICATION
  PAYMENT
  WALLET
  PAYOUT
  SUBSCRIPTION
}

// CRM Contact
model CRMContact {
  id          String   @id @default(cuid())
  
  type        CRMType
  contactId   String   // ID of the related entity (User, Author, Reseller, Lead)
  
  firstName   String
  lastName    String
  email       String
  phone       String?
  
  company     String?
  title       String?
  industry    String?
  
  source      String?  // Where the contact came from
  tags        String[] // Custom tags
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([contactId])
  @@index([email])
  @@index([tags])
}

enum CRMType {
  LEAD
  CUSTOMER
  AUTHOR
  RESELLER
}

// Pipeline Stage
model PipelineStage {
  id          String   @id @default(cuid())
  
  name        String
  description String?
  order       Int
  
  color       String?
  probability Int?     // Win probability at this stage
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
}

// Opportunity
model Opportunity {
  id          String   @id @default(cuid())
  
  contactId   String
  contact     CRMContact @relation(fields: [contactId], references: [id])
  
  stageId     String
  stage       PipelineStage @relation(fields: [stageId], references: [id])
  
  title       String
  description String?
  value       Float
  currency    String   @default("USD")
  
  expectedCloseDate DateTime?
  actualCloseDate   DateTime?
  
  status      OpportunityStatus @default(OPEN)
  probability Int      @default(0)
  
  assignedTo  String?  // User ID
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([contactId])
  @@index([stageId])
  @@index([status])
  @@index([expectedCloseDate])
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
  ABANDONED
}

// Follow Up
model FollowUp {
  id          String   @id @default(cuid())
  
  contactId   String
  contact     CRMContact @relation(fields: [contactId], references: [id])
  
  type        FollowUpType
  subject     String
  description String?
  
  dueDate     DateTime
  completedAt DateTime?
  status      FollowUpStatus @default(PENDING)
  
  assignedTo  String?  // User ID
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([contactId])
  @@index([dueDate])
  @@index([status])
  @@index([assignedTo])
}

enum FollowUpType {
  CALL
  EMAIL
  MEETING
  TASK
  REMINDER
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  SKIPPED
  CANCELLED
}

// Meeting Note
model MeetingNote {
  id          String   @id @default(cuid())
  
  contactId   String
  contact     CRMContact @relation(fields: [contactId], references: [id])
  
  title       String
  description String?
  
  meetingDate DateTime
  duration    Int?     // Minutes
  
  attendees   String[] // User IDs
  location    String?
  meetingType MeetingType
  
  outcome     String?
  actionItems Json?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([contactId])
  @@index([meetingDate])
}

enum MeetingType {
  IN_PERSON
  CALL
  VIDEO
  CHAT
}

// Call Note
model CallNote {
  id          String   @id @default(cuid())
  
  contactId   String
  contact     CRMContact @relation(fields: [contactId], references: [id])
  
  subject     String
  description String?
  
  callDate    DateTime
  duration    Int?     // Minutes
  direction   CallDirection
  
  phoneNumber String?
  outcome     String?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([contactId])
  @@index([callDate])
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

// Task Assignment
model TaskAssignment {
  id          String   @id @default(cuid())
  
  contactId   String?
  contact     CRMContact? @relation(fields: [contactId], references: [id])
  
  title       String
  description String?
  
  dueDate     DateTime?
  completedAt DateTime?
  status      TaskStatus @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  
  assignedTo  String   // User ID
  assignedBy  String   // User ID
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([contactId])
  @@index([assignedTo])
  @@index([dueDate])
  @@index([status])
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Customer Journey
model CustomerJourney {
  id          String   @id @default(cuid())
  
  contactId   String
  contact     CRMContact @relation(fields: [contactId], references: [id])
  
  stage       JourneyStage
  description String?
  
  enteredAt   DateTime @default(now())
  exitedAt    DateTime?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([contactId])
  @@index([stage])
}

enum JourneyStage {
  AWARENESS
  INTEREST
  CONSIDERATION
  INTENT
  EVALUATION
  PURCHASE
  RETENTION
  ADVOCACY
}

// Customer Health Score
model CustomerHealthScore {
  id          String   @id @default(cuid())
  
  contactId   String
  contact     CRMContact @relation(fields: [contactId], references: [id])
  
  score       Int      // 0-100
  category    HealthCategory
  
  factors     Json?    // Factors affecting the score
  
  calculatedAt DateTime @default(now())
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([contactId])
  @@index([score])
  @@index([category])
}

enum HealthCategory {
  EXCELLENT
  GOOD
  AVERAGE
  POOR
  CRITICAL
}

// Lost Customer Recovery
model LostCustomerRecovery {
  id          String   @id @default(cuid())
  
  contactId   String
  contact     CRMContact @relation(fields: [contactId], references: [id])
  
  reason      String
  description String?
  
  recoveryAttempts Int @default(0)
  lastAttemptAt DateTime?
  
  status      RecoveryStatus @default(NEW)
  recoveredAt DateTime?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([contactId])
  @@index([status])
}

enum RecoveryStatus {
  NEW
  IN_PROGRESS
  RECOVERED
  ABANDONED
}

// Automation Workflow
model AutomationWorkflow {
  id          String   @id @default(cuid())
  
  name        String
  description String?
  
  enabled     Boolean  @default(true)
  
  triggers    Json     // Array of trigger definitions
  conditions  Json     // Array of condition definitions
  actions     Json     // Array of action definitions
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  executions  WorkflowExecution[]

  @@index([enabled])
}

// Workflow Execution
model WorkflowExecution {
  id          String   @id @default(cuid())
  
  workflowId  String
  workflow    AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  
  triggeredBy String   // Entity that triggered the workflow
  triggerData Json?
  
  status      ExecutionStatus @default(PENDING)
  
  startedAt   DateTime @default(now())
  completedAt DateTime?
  errorMessage String?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workflowId])
  @@index([status])
}

enum ExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

// Automation Trigger
model AutomationTrigger {
  id          String   @id @default(cuid())
  
  type        TriggerType
  config      Json     // Trigger-specific configuration
  
  enabled     Boolean  @default(true)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([enabled])
}

enum TriggerType {
  EVENT
  SCHEDULE
  CONDITION
  WEBHOOK
  MANUAL
}

// Automation Condition
model AutomationCondition {
  id          String   @id @default(cuid())
  
  type        ConditionType
  config      Json     // Condition-specific configuration
  
  enabled     Boolean  @default(true)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([enabled])
}

enum ConditionType {
  EQUALS
  NOT_EQUALS
  GREATER_THAN
  LESS_THAN
  CONTAINS
  NOT_CONTAINS
  CUSTOM
}

// Automation Action
model AutomationAction {
  id          String   @id @default(cuid())
  
  type        ActionType
  config      Json     // Action-specific configuration
  
  enabled     Boolean  @default(true)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([enabled])
}

enum ActionType {
  ASSIGN
  FOLLOW_UP
  REMINDER
  ESCALATE
  RENEWAL
  NOTIFICATION
  PAYOUT
  APPROVAL
  WEBHOOK
  EMAIL
  SMS
  CUSTOM
}

// Auto Assignment Rule
model AutoAssignmentRule {
  id          String   @id @default(cuid())
  
  name        String
  description String?
  
  entityType  String   // Ticket, Lead, Opportunity, etc.
  conditions  Json     // Conditions for assignment
  
  assignTo    String   // User ID or role
  strategy    AssignmentStrategy @default(ROUND_ROBIN)
  
  enabled     Boolean  @default(true)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([entityType])
  @@index([enabled])
}

enum AssignmentStrategy {
  ROUND_ROBIN
  LEAST_LOADED
  RANDOM
  PRIORITY
}

// Auto Follow Up Rule
model AutoFollowUpRule {
  id          String   @id @default(cuid())
  
  name        String
  description String?
  
  entityType  String   // Contact, Ticket, Lead, etc.
  conditions  Json     // Conditions for follow-up
  delay       Int      // Hours before follow-up
  
  template    String?  // Message template
  channel     FollowUpChannel @default(EMAIL)
  
  enabled     Boolean  @default(true)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([entityType])
  @@index([enabled])
}

enum FollowUpChannel {
  EMAIL
  SMS
  WHATSAPP
  IN_APP
}

// Auto Reminder Rule
model AutoReminderRule {
  id          String   @id @default(cuid())
  
  name        String
  description String?
  
  reminderType ReminderType
  conditions  Json     // Conditions for reminder
  schedule    Json     // Schedule configuration
  
  template    String?  // Message template
  channel     FollowUpChannel @default(EMAIL)
  
  enabled     Boolean  @default(true)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([reminderType])
  @@index([enabled])
}

enum ReminderType {
  RENEWAL
  PAYMENT
  TASK
  MEETING
  FOLLOW_UP
  CUSTOM
}

// Auto Escalation Rule
model AutoEscalationRule {
  id          String   @id @default(cuid())
  
  name        String
  description String?
  
  entityType  String   // Ticket, Lead, Opportunity, etc.
  conditions  Json     // Conditions for escalation
  timeThreshold Int    // Minutes before escalation
  
  escalateTo  String   // User ID or role
  notify      Boolean  @default(true)
  
  enabled     Boolean  @default(true)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([entityType])
  @@index([enabled])
}

// Auto Renewal Rule
model AutoRenewalRule {
  id          String   @id @default(cuid())
  
  name        String
  description String?
  
  entityType  String   // License, Subscription
  conditions  Json     // Conditions for auto-renewal
  
  renewalPeriod String // monthly, yearly
  paymentMethod String
  
  enabled     Boolean  @default(true)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([entityType])
  @@index([enabled])
}

// Auto Notification Rule
model AutoNotificationRule {
  id          String   @id @default(cuid())
  
  name        String
  description String?
  
  eventType   String   // Event type to trigger notification
  conditions  Json     // Conditions for notification
  
  template    String?  // Message template
  channels    String[] // email, sms, push, in-app
  
  enabled     Boolean  @default(true)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([eventType])
  @@index([enabled])
}

// Auto Payout Rule
model AutoPayoutRule {
  id          String   @id @default(cuid())
  
  name        String
  description String?
  
  entityType  String   // Author, Reseller
  conditions  Json     // Conditions for auto-payout
  
  threshold   Float    // Minimum balance for payout
  schedule    Json     // Schedule configuration
  
  enabled     Boolean  @default(true)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([entityType])
  @@index([enabled])
}

// Auto Approval Rule
model AutoApprovalRule {
  id          String   @id @default(cuid())
  
  name        String
  description String?
  
  entityType  String   // Product, KYC, Payout, etc.
  conditions  Json     // Conditions for auto-approval
  
  enabled     Boolean  @default(true)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([entityType])
  @@index([enabled])
}

// Finance OS - General Ledger
model GeneralLedger {
  id          String   @id @default(cuid())
  
  accountCode String
  accountName String
  accountType LedgerAccountType
  
  balance     Decimal  @default(0) @db.Decimal(20, 2)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries     LedgerEntry[]

  @@unique([accountCode])
  @@index([accountType])
}

enum LedgerAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

// Ledger Entry
model LedgerEntry {
  id          String   @id @default(cuid())
  
  ledgerId    String
  ledger      GeneralLedger @relation(fields: [ledgerId], references: [id])
  
  entryType   EntryType
  amount      Decimal  @db.Decimal(20, 2)
  description String?
  
  referenceId String?  // Reference to order, payment, etc.
  referenceType String?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ledgerId])
  @@index([entryType])
  @@index([referenceId])
}

enum EntryType {
  DEBIT
  CREDIT
}

// Income Ledger
model IncomeLedger {
  id          String   @id @default(cuid())
  
  source      IncomeSource
  amount      Decimal  @db.Decimal(20, 2)
  currency    String   @default("USD")
  
  referenceId String?
  referenceType String?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([source])
  @@index([createdAt])
}

enum IncomeSource {
  PRODUCT_SALE
  SUBSCRIPTION
  COMMISSION
  REFERRAL
  OTHER
}

// Expense Ledger
model ExpenseLedger {
  id          String   @id @default(cuid())
  
  category    ExpenseCategory
  amount      Decimal  @db.Decimal(20, 2)
  currency    String   @default("USD")
  
  referenceId String?
  referenceType String?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([createdAt])
}

enum ExpenseCategory {
  OPERATIONAL
  MARKETING
  DEVELOPMENT
  SUPPORT
  INFRASTRUCTURE
  OTHER
}

// Commission Ledger
model CommissionLedger {
  id          String   @id @default(cuid())
  
  userId      String
  user        User     @relation("CommissionLedgerUser", fields: [userId], references: [id])
  
  orderId     String?
  productId   String?
  
  amount      Decimal  @db.Decimal(20, 2)
  rate        Float
  currency    String   @default("USD")
  
  status      CommissionStatus @default(PENDING)
  paidAt      DateTime?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

// Settlement Ledger
model SettlementLedger {
  id          String   @id @default(cuid())
  
  userId      String
  user        User     @relation("SettlementLedgerUser", fields: [userId], references: [id])
  
  amount      Decimal  @db.Decimal(20, 2)
  currency    String   @default("USD")
  
  status      SettlementStatus @default(PENDING)
  settledAt   DateTime?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum SettlementStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

// GST Report
model GSTReport {
  id          String   @id @default(cuid())
  
  period      String   // YYYY-MM
  startDate   DateTime
  endDate     DateTime
  
  totalRevenue Decimal @db.Decimal(20, 2)
  totalTax     Decimal @db.Decimal(20, 2)
  totalExpense Decimal @db.Decimal(20, 2)
  taxCredit    Decimal @db.Decimal(20, 2)
  netTax       Decimal @db.Decimal(20, 2)
  
  status      ReportStatus @default(DRAFT)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([period])
  @@index([status])
}

// TDS Report
model TDSReport {
  id          String   @id @default(cuid())
  
  period      String   // YYYY-MM
  startDate   DateTime
  endDate     DateTime
  
  totalDeductible Decimal @db.Decimal(20, 2)
  totalTax     Decimal @db.Decimal(20, 2)
  
  status      ReportStatus @default(DRAFT)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([period])
  @@index([status])
}

enum ReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

// Profit & Loss Statement
model ProfitLossStatement {
  id          String   @id @default(cuid())
  
  period      String   // YYYY-MM
  startDate   DateTime
  endDate     DateTime
  
  totalRevenue    Decimal @db.Decimal(20, 2)
  totalExpense    Decimal @db.Decimal(20, 2)
  grossProfit     Decimal @db.Decimal(20, 2)
  operatingExpense Decimal @db.Decimal(20, 2)
  netProfit       Decimal @db.Decimal(20, 2)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([period])
}

// Cash Flow Statement
model CashFlowStatement {
  id          String   @id @default(cuid())
  
  period      String   // YYYY-MM
  startDate   DateTime
  endDate     DateTime
  
  operatingCashFlow Decimal @db.Decimal(20, 2)
  investingCashFlow Decimal @db.Decimal(20, 2)
  financingCashFlow Decimal @db.Decimal(20, 2)
  netCashFlow       Decimal @db.Decimal(20, 2)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([period])
}

// Revenue Forecast
model RevenueForecast {
  id          String   @id @default(cuid())
  
  period      String   // YYYY-MM
  forecastType ForecastType
  
  forecastAmount Decimal @db.Decimal(20, 2)
  actualAmount   Decimal? @db.Decimal(20, 2)
  variance      Decimal? @db.Decimal(20, 2)
  
  confidence   Float?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([period])
  @@index([forecastType])
}

enum ForecastType {
  MONTHLY
  QUARTERLY
  YEARLY
}

// Product Approval Workflow
model ProductApproval {
  id          String   @id @default(cuid())
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  status      ApprovalStatus @default(DRAFT)
  
  submittedBy String
  submittedAt DateTime?
  
  reviewedBy  String?
  reviewedAt  DateTime?
  
  rejectionReason String?
  changeRequests  Json?
  
  publishedAt DateTime?
  archivedAt  DateTime?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([status])
  @@index([submittedBy])
}

enum ApprovalStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  NEEDS_CHANGES
  PUBLISHED
  ARCHIVED
}

// Digital Asset Protection
model DownloadWatermark {
  id          String   @id @default(cuid())
  
  userId      String
  user        User     @relation("DownloadWatermarkUser", fields: [userId], references: [id])
  
  productId   String
  licenseId   String?
  
  watermarkType WatermarkType
  watermarkData Json?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([productId])
  @@index([licenseId])
}

enum WatermarkType {
  TEXT
  IMAGE
  INVISIBLE
  FINGERPRINT
}

// Leak Tracking
model LeakReport {
  id          String   @id @default(cuid())
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  source      String
  sourceUrl   String?
  
  reportedBy  String
  reportedAt  DateTime @default(now())
  
  status      LeakStatus @default(NEW)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([status])
}

enum LeakStatus {
  NEW
  INVESTIGATING
  CONFIRMED
  FALSE_POSITIVE
  RESOLVED
}

// Download Fingerprinting
model DownloadFingerprint {
  id          String   @id @default(cuid())
  
  userId      String
  user        User     @relation("DownloadFingerprintUser", fields: [userId], references: [id])
  
  productId   String
  licenseId   String?
  
  fingerprint String
  deviceInfo  Json?
  ipAddress   String?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([productId])
  @@index([fingerprint])
}

// Secure File Delivery
model SecureDelivery {
  id          String   @id @default(cuid())
  
  productId   String
  licenseId   String?
  
  deliveryUrl String
  accessKey   String
  
  expiresAt   DateTime
  accessCount Int      @default(0)
  maxAccess   Int?
  
  status      DeliveryStatus @default(ACTIVE)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([licenseId])
  @@index([status])
}

enum DeliveryStatus {
  ACTIVE
  EXPIRED
  REVOKED
  CONSUMED
}

// Abuse Detection
model AbuseReport {
  id          String   @id @default(cuid())
  
  type        AbuseType
  severity    AbuseSeverity
  
  userId      String?
  productId   String?
  licenseId   String?
  
  description String
  evidence    Json?
  
  status      AbuseStatus @default(NEW)
  
  resolvedBy  String?
  resolvedAt  DateTime?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([status])
  @@index([userId])
  @@index([productId])
}

enum AbuseType {
  DOWNLOAD_ABUSE
  SHARING_ABUSE
  LICENSE_ABUSE
  PAYMENT_ABUSE
  REFUND_ABUSE
  OTHER
}

enum AbuseSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AbuseStatus {
  NEW
  INVESTIGATING
  CONFIRMED
  FALSE_POSITIVE
  RESOLVED
  IGNORED
}

// Product Health Center
model CrashReport {
  id          String   @id @default(cuid())
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  userId      String?
  user        User?    @relation("CrashReportUser", fields: [userId], references: [id])
  
  version     String
  platform    String
  os          String?
  
  stackTrace  String
  errorMessage String?
  
  status      CrashStatus @default(NEW)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([status])
  @@index([version])
}

enum CrashStatus {
  NEW
  INVESTIGATING
  CONFIRMED
  FIXED
  IGNORED
}

// Product Bug Report
model ProductBugReport {
  id          String   @id @default(cuid())
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  userId      String?
  user        User?    @relation("ProductBugReportUser", fields: [userId], references: [id])
  
  title       String
  description String
  severity    BugSeverity
  priority    BugPriority
  
  status      BugStatus @default(NEW)
  
  assignedTo  String?
  resolvedAt  DateTime?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([status])
  @@index([severity])
}

enum BugSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BugPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum BugStatus {
  NEW
  IN_PROGRESS
  IN_REVIEW
  RESOLVED
  CLOSED
}

// Issue Tracking
model Issue {
  id          String   @id @default(cuid())
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
