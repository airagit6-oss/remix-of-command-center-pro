  resolvedBy  String?
  resolvedAt  DateTime?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([userId])
  @@index([status])
}

enum ComplaintCategory {
  FUNCTIONALITY
  PERFORMANCE
  USABILITY
  DOCUMENTATION
  SUPPORT
  BILLING
  OTHER
}

enum ComplaintSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ComplaintStatus {
  NEW
  INVESTIGATING
  IN_PROGRESS
  RESOLVED
  CLOSED
  ESCALATED
}

// Customer Success Center
model CustomerOnboarding {
