  crashRate   Float    @default(0)
  bugCount    Int      @default(0)
  issueCount  Int      @default(0)
  
  healthScore Float    @default(100)
  
  status      VersionHealthStatus @default(HEALTHY)
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([version])
  @@index([status])
}

enum VersionHealthStatus {
  HEALTHY
  DEGRADED
  UNHEALTHY
  CRITICAL
}

// User Complaint
model UserComplaint {
  id          String   @id @default(cuid())
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
