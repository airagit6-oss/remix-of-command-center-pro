  title       String
  description String
  severity    IssueSeverity
  
  status      IssueStatus @default(OPEN)
  
  assignedTo  String?
  resolvedAt  DateTime?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([status])
  @@index([type])
}

enum IssueType {
  BUG
  FEATURE_REQUEST
  IMPROVEMENT
  DOCUMENTATION
  PERFORMANCE
  SECURITY
}

enum IssueSeverity {
  TRIVIAL
  MINOR
  MAJOR
  CRITICAL
  BLOCKER
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  IN_REVIEW
  RESOLVED
  CLOSED
  REOPENED
}

// Known Issues
model KnownIssue {
  id          String   @id @default(cuid())
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
  version     String
  title       String
  description String
  workaround  String?
  
  severity    IssueSeverity
  status      KnownIssueStatus @default(ACTIVE)
  
  fixedInVersion String?
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId])
  @@index([status])
  @@index([version])
}

enum KnownIssueStatus {
  ACTIVE
  INVESTIGATING
  FIXING
  FIXED
  IGNORED
}

// Version Health
model VersionHealth {
  id          String   @id @default(cuid())
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  
