# ════════════════════════════════════════════════════
# BACKEND ENVIRONMENT VARIABLES
# ════════════════════════════════════════════════════

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/remix_pro_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production-12345"

# Server
NODE_ENV="production"
PORT=3000

# CORS
CORS_ORIGIN="http://localhost:4173,http://localhost:3000,https://softwarevala.net,https://www.softwarevala.net"

# Redis
REDIS_URL="redis://localhost:6379"

# Stripe
STRIPE_SECRET_KEY="sk_test_your_stripe_key_here"
STRIPE_WEBHOOK_SECRET="whsec_test_your_webhook_secret_here"

# Supabase (for reference, but using PostgreSQL directly)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-supabase-anon-key"

# Email (for notifications)
SENDGRID_API_KEY="SG.your_sendgrid_api_key_here"
SENDGRID_FROM_EMAIL="noreply@softwarevala.net"

# External Services
MEILISEARCH_URL="http://localhost:7700"
MEILISEARCH_API_KEY="your-meilisearch-key"
