{
  "name": "software-vala-ai-api-manager-backend",
  "version": "1.0.0",
  "description": "Real backend with MongoDB for Software Vala AI API Manager",
  "main": "dist/src/server/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server/index.ts",
    "build": "tsc",
    "start": "node dist/src/server/index.js",
    "type-check": "tsc --noEmit",
    "seed": "ts-node src/server/scripts/seed.ts",
    "migrate": "ts-node src/server/scripts/migrate.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.0",
    "axios": "^1.5.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.8.0",
    "@types/mongoose": "^5.11.97",
    "@types/cors": "^2.8.14",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1",
    "@types/jsonwebtoken": "^9.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
