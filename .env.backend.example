# ============================================================================
# AI API MANAGER - BACKEND CONFIGURATION
# ============================================================================

# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Database - MongoDB
MONGODB_URI=mongodb://localhost:27017/software-vala-ai-api-manager

# For MongoDB Atlas, use:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database-name?retryWrites=true&w=majority

# For Docker MongoDB, use:
# MONGODB_URI=mongodb://mongo:27017/software-vala-ai-api-manager

# ============================================================================
# API KEYS & SECRETS (for real integrations)
# ============================================================================

# OpenAI
OPENAI_API_KEY=sk-...

# Claude (Anthropic)
CLAUDE_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=

# Stripe
STRIPE_API_KEY=sk_live_...
STRIPE_SECRET_KEY=sk_live_...

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# SendGrid
SENDGRID_API_KEY=

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Azure
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=

# Google Cloud
GCP_PROJECT_ID=
GCP_SERVICE_ACCOUNT_JSON=

# ============================================================================
# AUTHENTICATION
# ============================================================================

JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=7d

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

LOG_LEVEL=debug
LOG_FORMAT=combined

# ============================================================================
# CACHE
# ============================================================================

REDIS_URL=redis://localhost:6379

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@softwarevala.com

# ============================================================================
# API RATE LIMITING
# ============================================================================

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=15000

# ============================================================================
# FEATURES & FLAGS
# ============================================================================

ENABLE_AI_DISCOVERY=true
ENABLE_WEBHOOK_SYNC=true
ENABLE_AUTO_BILLING=true
ENABLE_HEALTH_CHECKS=true
