# Production Environment Configuration
# DO NOT commit actual secrets to version control

# Database
DATABASE_URL="postgresql://user:password@prod-db-host:5432/command_center?schema=public"
DATABASE_POOL_SIZE="50"
DATABASE_TIMEOUT="30000"

# Server
SERVER_PORT=4000
NODE_ENV=production
CLIENT_ORIGIN="https://example.com"

# JWT
JWT_ACCESS_SECRET="your-super-secret-access-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# Cookies
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=".example.com"

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_SUCCESS_URL="https://example.com/checkout/success"
STRIPE_CANCEL_URL="https://example.com/cart"

# AI
AI_PROVIDER="openai"
AI_API_KEY="sk-..."
AI_MODEL="gpt-4o-mini"
AI_MAX_OUTPUT_TOKENS=1200
AI_DAILY_USER_LIMIT=100
AUTOMATION_WORKER_INTERVAL_MS=60000

# S3 / Media
S3_BUCKET="your-production-bucket"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="AKIA..."
S3_SECRET_ACCESS_KEY="..."
S3_ENDPOINT=""
CDN_URL="https://cdn.example.com"
MEDIA_MAX_UPLOAD_MB=50
MEDIA_ALLOWED_TYPES="image/jpeg,image/png,image/webp,image/gif,video/mp4,application/pdf"

# Analytics
ANALYTICS_RETENTION_DAYS=90
ANALYTICS_AGGREGATION_INTERVAL_HOURS=1

# Email / Communication
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASSWORD="SG...."
SMTP_FROM="noreply@example.com"
SENDGRID_API_KEY="SG...."

# Redis (Caching)
REDIS_URL="redis://prod-redis-host:6379"

# Multi-Region Configuration
PRIMARY_REGION="us-east-1"
SECONDARY_REGION="us-west-2"
