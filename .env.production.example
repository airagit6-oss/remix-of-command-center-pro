# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION ENVIRONMENT CONFIGURATION - EXAMPLE TEMPLATE
# ═══════════════════════════════════════════════════════════════════════════════
# ⚠️  SECURITY: Never commit .env.production with real secrets to git!
# Copy this file to .env.production and replace [PLACEHOLDERS] with actual values
# .env.production is in .gitignore and will not be tracked

# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND Configuration
# ─────────────────────────────────────────────────────────────────────────────

# API Base URL - Where frontend makes requests to the backend
# This should point to your backend API endpoint
# Examples:
#   - https://www.softwarevala.net/api/v1 (same domain, proxied by nginx)
#   - https://api.softwarevala.net/v1 (separate backend subdomain)
VITE_API_URL=https://www.softwarevala.net/api/v1

NODE_ENV=production
APP_DOMAIN=softwarevala.net

# ─────────────────────────────────────────────────────────────────────────────
# BACKEND Configuration (if running separately)
# ─────────────────────────────────────────────────────────────────────────────

PORT=3000
API_PREFIX=api/v1

# Database (PostgreSQL/Supabase)
# ⚠️  STORE REAL SECRETS IN YOUR DEPLOYMENT ENVIRONMENT
DATABASE_URL=postgresql://user:[PASSWORD]@db.[REGION].supabase.co:5432/postgres
SUPABASE_URL=https://[PROJECT_ID].supabase.co
SUPABASE_ANON_KEY=[ANON_KEY]
SUPABASE_SERVICE_ROLE_KEY=[SERVICE_ROLE_KEY]

# JWT Secrets (minimum 32 characters)
JWT_SECRET=[CHANGE_IN_PRODUCTION_MIN_32_CHARS]
JWT_REFRESH_SECRET=[CHANGE_IN_PRODUCTION_MIN_32_CHARS]
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis Cache
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=[REDIS_PASSWORD]

# CORS
CORS_ORIGIN=https://www.softwarevala.net

# ─────────────────────────────────────────────────────────────────────────────
# Optional Third-Party Services
# ─────────────────────────────────────────────────────────────────────────────

# Stripe
STRIPE_SECRET_KEY=[STRIPE_SECRET_KEY]
STRIPE_WEBHOOK_SECRET=[STRIPE_WEBHOOK_SECRET]

# SendGrid Email
SENDGRID_API_KEY=[SENDGRID_API_KEY]

# Cloudflare (if using)
CLOUDFLARE_ZONE_ID=[CLOUDFLARE_ZONE_ID]
CLOUDFLARE_API_TOKEN=[CLOUDFLARE_API_TOKEN]
